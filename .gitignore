# ──────────────────────────────────────────
# macOS
# ──────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ──────────────────────────────────────────
# IDE — IntelliJ IDEA / VS Code
# ──────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/

# ──────────────────────────────────────────
# Backend — Gradle build artifacts
# ──────────────────────────────────────────
backend/.gradle/
backend/build/
backend/bin/
backend/out/

# Keep Gradle wrapper JARs (needed to build without installing Gradle)
!backend/gradle/wrapper/gradle-wrapper.jar

# ──────────────────────────────────────────
# Frontend — Node / Vite
# ──────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# ──────────────────────────────────────────
# Logs
# ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────
# Misc
# ──────────────────────────────────────────
*.zip

*.env